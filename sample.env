# ==============================
# Runtime Config (for API testing)
# ==============================
# 배포 완료 후 end-user가 APIM을 통해 모델을 호출할 때 필요한 설정
# 인프라 배포 설정은 infra/terraform.tfvars.example 참조

# APIM Endpoint
APIM_ENDPOINT=https://<apim-name>.azure-api.net
APIM_SUBSCRIPTION_KEY=

# Model
DEPLOYMENT_NAME=gpt-4o
API_VERSION=2024-12-01-preview
