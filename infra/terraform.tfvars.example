# ============================================================================
# Azure Subscription
# ============================================================================
# ⚠️  Verify your subscription_id before running terraform apply.
#     Run: az account show --query id -o tsv
subscription_id     = ""
resource_group_name = "rg-apim-foundry"
location            = "koreacentral"

# ============================================================================
# API Management (APIM)
# ============================================================================
# ⚠️  apim_name must be globally unique across all Azure tenants.
#     Recommended format: apim-foundry-gw-{company}-{environment}
#     Example: apim-foundry-gw-contoso-dev
apim_name            = "apim-foundry-gw-mycompany-dev"
apim_sku             = "Developer_1" # Production: StandardV2_1
apim_publisher_name  = "AI Platform Team"
apim_publisher_email = "apim@example.com"

# ============================================================================
# Azure AI Foundry (shared resource)
# ============================================================================
# Name of the shared Azure AI Services (Foundry) resource.
foundry_resource_name = "aoai-foundry"

# Foundry Projects (팀별 — each becomes a child resource under the shared Foundry account)
foundry_projects = ["catalog-project", "image-project"]

# ============================================================================
# Model Deployments
# ============================================================================
# Default rate limit applied when a deployment omits rate_limit_tpm.
default_rate_limit_tpm = 10000

# Shared model deployments at the Foundry resource level.
# Each object supports: name, model_name, model_version (required),
#   sku_name (optional, default "GlobalStandard"),
#   rate_limit_tpm (optional, uses default_rate_limit_tpm if omitted).
#
# ⚠️  model_version format varies by model. Check region availability:
#     https://learn.microsoft.com/azure/ai-services/openai/concepts/models
model_deployments = [
  {
    name           = "gpt-4o"
    model_name     = "gpt-4o"
    model_version  = "2024-11-20"
    sku_name       = "GlobalStandard"
    rate_limit_tpm = 10000
  },
  {
    name          = "gpt-4o-mini"
    model_name    = "gpt-4o-mini"
    model_version = "2024-07-18"
    # sku_name and rate_limit_tpm use defaults when omitted
  }
]

# ============================================================================
# Monitoring
# ============================================================================
app_insights_name            = "appi-foundry"
log_analytics_workspace_name = "law-foundry"
