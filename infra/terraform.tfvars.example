# Azure
subscription_id     = ""
resource_group_name = "rg-apim-foundry"
location            = "koreacentral"

# APIM
apim_name            = "apim-foundry-gw"
apim_sku             = "Developer_1" # Production: StandardV2_1
apim_publisher_name  = "AI Platform Team"
apim_publisher_email = "apim@example.com"

# Foundry Projects (팀별 — child resources under the shared Foundry account)
foundry_projects = ["catalog", "image"]

# Shared model deployments at the Foundry resource level
model_deployments = [
  {
    name          = "gpt-4o"
    model_name    = "gpt-4o"
    model_version = "2024-08-06"
  },
  {
    name          = "gpt-5.4"
    model_name    = "gpt-5.4"
    model_version = "2025-04-14"
  },
  {
    name          = "gpt-5.2"
    model_name    = "gpt-5.2"
    model_version = "2025-03-20"
  }
]

# Monitoring
app_insights_name            = "appi-foundry"
log_analytics_workspace_name = "law-foundry"
