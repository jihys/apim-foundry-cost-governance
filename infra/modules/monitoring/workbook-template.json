          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "customMetrics\n| where name == \"TokenUsage\"\n| extend model = tostring(customDimensions[\"model\"]),\n         projectName = tostring(customDimensions[\"project-name\"]),\n         promptTokens = todouble(customDimensions[\"prompt-tokens\"]),\n         completionTokens = todouble(customDimensions[\"completion-tokens\"]),\n         totalTokens = value\n| summarize PromptTokens = sum(promptTokens),\n            CompletionTokens = sum(completionTokens),\n            TotalTokens = sum(totalTokens)\n         by projectName, model\n| order by TotalTokens desc",
              "size": 0,
              "title": "프로젝트별 모델별 토큰 사용량",
              "timeContext": {
                "durationMs": 0
