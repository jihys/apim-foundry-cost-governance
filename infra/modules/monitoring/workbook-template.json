    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "customMetrics\n| where name == \"TokenUsage\"\n| extend projectName = tostring(customDimensions[\"project-name\"])\n| summarize TotalTokens = sum(value) by projectName\n| order by TotalTokens desc",
        "size": 0,
        "title": "프로젝트별 총 토큰 사용량",
        "timeContext": {
          "durationMs": 0
        },
        "timeContextFromParameter": "TimeRange",
        "queryType": 0,
        "resourceType": "microsoft.insights/components",
        "visualization": "barchart",
        "chartSettings": {
          "xAxis": "projectName",
          "yAxis": [
            "TotalTokens"
          ]
        }
      },
      "name": "tokensByProject"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "customMetrics\n| where name == \"TokenUsage\"\n| extend projectName = tostring(customDimensions[\"project-name\"])\n| summarize TotalTokens = sum(value) by bin(timestamp, 1d), projectName\n| order by timestamp asc",
        "size": 0,
        "title": "프로젝트별 일별 추이",
        "timeContext": {
          "durationMs": 0
        },
        "timeContextFromParameter": "TimeRange",
        "queryType": 0,
